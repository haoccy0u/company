[gd_resource type="Resource" script_class="PassiveTemplate" load_steps=2 format=3]

[ext_resource type="Script" path="res://src/expedition_system/battle/PassiveTemplate.gd" id="1_passive"]
[ext_resource type="Script" path="res://src/expedition_system/actor/behavior/PassiveEffectSpec.gd" id="2_effect"]

[sub_resource type="Resource" id="1_heal_ally"]
script = ExtResource("2_effect")
effect_id = &"heal_one_ally_on_attack"
trigger_id = &"on_attack_hit"
effect_type = &"heal_ally"
target_rule = &"lowest_hp_percent_ally"
params = {
"heal_amount_flat": 8.0,
"heal_scale_attr": &"atk",
"heal_scale_ratio": 0.2,
"heal_target_rule": &"lowest_hp_percent_ally"
}

[resource]
script = ExtResource("1_passive")
passive_id = &"attack_heal_ally"
display_name = "Support Repair"
description = "On attack hit, heal the allied unit with the lowest HP percentage."
trigger_id = &"on_attack_hit"
effect_tags = Array[StringName]([&"heal_one_ally_on_attack"])
params = {
"heal_amount_flat": 8.0,
"heal_scale_attr": &"atk",
"heal_scale_ratio": 0.2,
"heal_target_rule": &"lowest_hp_percent_ally"
}
effects = Array[Resource]([SubResource("1_heal_ally")])
