[gd_resource type="Resource" script_class="ActorTemplate" format=3]

[ext_resource type="Script" path="res://src/expedition_system/squad/ActorTemplate.gd" id="1_actor"]
[ext_resource type="Resource" path="res://data/devtest/expedition/actors/attrs/robot_attr_set.tres" id="2_attr_set"]

[resource]
script = ExtResource("1_actor")
template_id = &"robot"
display_name = "机器人"
base_attr_set = ExtResource("2_attr_set")
