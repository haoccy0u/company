[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scenes/devtest/panels/ExpeditionSessionTestPanel.gd" id="1_panel"]

[node name="ExpeditionSessionTestPanel" type="VBoxContainer"]
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 8
script = ExtResource("1_panel")

[node name="TitleLabel" type="Label" parent="."]
layout_mode = 2
text = "Expedition Session (Step 2)"
theme_override_font_sizes/font_size = 18

[node name="TipsLabel" type="Label" parent="."]
layout_mode = 2
autowrap_mode = 2
text = "Use this panel as a validation tool: the upper report gives PASS/WAIT checks, the lower summary gives fixed battle metrics."

[node name="ConfigFrame" type="PanelContainer" parent="."]
layout_mode = 2
size_flags_horizontal = 3

[node name="ConfigVBox" type="VBoxContainer" parent="ConfigFrame"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="LocationRow" type="HBoxContainer" parent="ConfigFrame/ConfigVBox"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="LocationIdLabel" type="Label" parent="ConfigFrame/ConfigVBox/LocationRow"]
layout_mode = 2
text = "Location ID"

[node name="LocationIdEdit" type="LineEdit" parent="ConfigFrame/ConfigVBox/LocationRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "forest_outpost"
placeholder_text = "forest_outpost"

[node name="EventSequenceRow" type="HBoxContainer" parent="ConfigFrame/ConfigVBox"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="EventSequenceLabel" type="Label" parent="ConfigFrame/ConfigVBox/EventSequenceRow"]
layout_mode = 2
text = "Event Sequence"

[node name="EventSequenceEdit" type="LineEdit" parent="ConfigFrame/ConfigVBox/EventSequenceRow"]
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "combat:training_dummy,rest"
text = "combat:training_dummy,rest"

[node name="InfoLabel" type="Label" parent="ConfigFrame/ConfigVBox"]
layout_mode = 2
size_flags_horizontal = 3
autowrap_mode = 2
text = "Uses observer + robot from resources by default. Example sequence: combat:training_dummy,rest,combat:wolves"

[node name="HpPolicyRow" type="HBoxContainer" parent="ConfigFrame/ConfigVBox"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="HpPolicyLabel" type="Label" parent="ConfigFrame/ConfigVBox/HpPolicyRow"]
layout_mode = 2
text = "HP Policy"

[node name="HpPolicyOption" type="OptionButton" parent="ConfigFrame/ConfigVBox/HpPolicyRow"]
layout_mode = 2
size_flags_horizontal = 3

[node name="ButtonRow" type="HBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 8

[node name="BuildSessionButton" type="Button" parent="ButtonRow"]
layout_mode = 2
