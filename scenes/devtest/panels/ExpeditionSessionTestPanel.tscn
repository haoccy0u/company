[node name="CompleteEventButton" type="Button" parent="ButtonRow"]
layout_mode = 2
text = "Skip Event"

[node name="EndSessionButton" type="Button" parent="ButtonRow"]
layout_mode = 2
text = "End Session"

[node name="ResetButton" type="Button" parent="ButtonRow"]
layout_mode = 2
text = "Reset"

[node name="StatusLabel" type="Label" parent="."]
layout_mode = 2
autowrap_mode = 2
text = "Ready"

[node name="CheckpointFrame" type="PanelContainer" parent="."]
layout_mode = 2
size_flags_horizontal = 3

[node name="CheckpointVBox" type="VBoxContainer" parent="CheckpointFrame"]
